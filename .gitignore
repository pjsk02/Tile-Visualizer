# Dependencies
node_modules/
yarn.lock
# package-lock.json IS committed on purpose: all deps are installed up front (see
# CLAUDE.md) so both devs share the exact same resolved versions and never hit a
# lockfile merge conflict.

# Build outputs
dist/
build/
.next/
out/

# Gaussian-splat & video exports (generated on Kaggle, downloaded separately)
*.ply
*.spz
*.mp4
*.webm

# Raw catalog source scan (already extracted into catalog.json/csv + images/)
2ft by 4ft Catalog.pdf

# Environment & secrets
.env
.env.local
.env.*.local

# Local IDE / Claude settings (machine-specific)
.claude/settings.local.json
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.log

# Test coverage
coverage/

# Regenerable QA screenshots (npm run qa:showroom)
showroom-qa-screenshots/

# Graphify extraction cache (regenerable, machine-local hash cache/paths)
graphify-out/cache/
graphify-out/.graphify_analysis.json
graphify-out/.graphify_python
